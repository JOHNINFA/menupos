# Variables de entorno del frontend (Vite).
# Copia como .env.local para desarrollo, o configúralas en Vercel para producción.
# IMPORTANTE: en Vite las variables deben empezar con VITE_ para ser visibles.

# URL base de la API del backend.
# - Desarrollo: déjala vacía o comentada (usa http://localhost:8000/api por defecto).
# - Producción: la URL de tu backend en Railway + /api
#   ej: https://menupos-production.up.railway.app/api
VITE_API_URL=
