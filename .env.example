# ============================================
# .env.example — Plantilla de variables de entorno
# ============================================
# Copia este archivo como .env y pon los valores reales.
# El archivo .env nunca se sube a Git (está en .gitignore).
# ============================================
# ¿Por qué? Estas son "claves" que debes mantener en secreto.
# Si subes esto público, cualquiera puede usar tu BD o tu cuenta AWS.
# ============================================

# ─── Django ──────────────────────────────────
# SECRET_KEY: clave para encriptación de sesiones, cookies, etc.
# Generar una nueva con: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=cambiar-en-produccion-usar-clave-real

# DEBUG: true en desarrollo, false en producción
DJANGO_DEBUG=true

# Dominios permitidos (en desarrollo localhost basta)
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Base de datos ────────────────────────────
# FASE 2 usa SQLite (cero configuración, cero variables necesarias).
# Cuando migremos a PostgreSQL con Docker (fase futura), aquí se
# agregarán las variables DB_NAME, DB_USER, DB_PASSWORD, DB_HOST, DB_PORT.

# ─── CORS (qué frontend puede llamar a la API) ───
# En desarrollo: el de Vite
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ─── JWT (tokens de autenticación) ───────────
# Tiempo de vida del token (en minutos)
JWT_ACCESS_TOKEN_LIFETIME_MIN=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ─── AWS S3 (para imágenes de productos) ─────
# Interruptor: false = imágenes en disco local (desarrollo).
#              true  = imágenes en el bucket de S3 (requiere las 4 variables de abajo).
# Ver instrucciones paso a paso en docs/clases/12-aws-s3.md
USE_S3=false

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1

# ─── Cloudinary (alternativa gratis para imágenes, sin tarjeta) ───
# Si pones estas 3 variables, las imágenes de productos se guardan y
# sirven desde Cloudinary (permanente). Si las dejas vacías, se usa el
# disco local (desarrollo). Ver docs/clases/13-cloudinary.md
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Azure Blob Storage (alternativa para imágenes) ───
# Si pones AZURE_ACCOUNT_NAME + AZURE_ACCOUNT_KEY, las imágenes se guardan
# en un container de Azure Blob (permanente). El container por defecto es
# "menupos-media" (debe existir en tu cuenta de almacenamiento).
AZURE_ACCOUNT_NAME=
AZURE_ACCOUNT_KEY=
AZURE_CONTAINER=menupos-media
